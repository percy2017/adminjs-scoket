APP_NAME=AdminJS
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# Base de datos
DB_CONNECTION=sqlite
DB_DATABASE=./database/adminjs.sqlite

# MySQL (descomenta para usar)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=adminjs
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (descomenta para usar)
# DB_CONNECTION=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=adminjs
# DB_USERNAME=postgres
# DB_PASSWORD=

# Seguridad
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-change-in-production

# SMTP (opcional)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=
