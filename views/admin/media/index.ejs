<div class="media-library">
  <div class="row g-3 mb-4">
    <div class="col-md-8">
      <ul class="nav nav-pills gap-2">
        <li class="nav-item">
          <a class="nav-link <%= filters.type === 'all' || !filters.type ? 'active' : '' %>" href="/admin/media?type=all">
            <i class="bi bi-grid"></i> Todos
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= filters.type === 'image' ? 'active' : '' %>" href="/admin/media?type=image">
            <i class="bi bi-image"></i> Imágenes
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= filters.type === 'video' ? 'active' : '' %>" href="/admin/media?type=video">
            <i class="bi bi-camera-video"></i> Videos
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= filters.type === 'audio' ? 'active' : '' %>" href="/admin/media?type=audio">
            <i class="bi bi-music-note"></i> Audio
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= filters.type === 'document' ? 'active' : '' %>" href="/admin/media?type=document">
            <i class="bi bi-file-earmark-text"></i> Documentos
          </a>
        </li>
      </ul>
    </div>
    <div class="col-md-4">
      <form method="GET" action="/admin/media" class="d-flex gap-2">
        <input type="hidden" name="type" value="<%= filters.type %>">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" name="search" class="form-control" placeholder="Buscar medios..." value="<%= filters.search || '' %>">
        </div>
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-search"></i>
        </button>
      </form>
    </div>
  </div>

  <div id="dropZone" class="drop-zone mb-4">
    <form id="uploadForm" action="/admin/media" method="POST" enctype="multipart/form-data">
      <input type="file" id="fileInput" name="file" multiple accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip">
    </form>
    <div class="drop-zone-content">
      <div class="drop-zone-icon">
        <i class="bi bi-cloud-arrow-up"></i>
      </div>
      <h5 class="mt-3">Arrastra archivos aquí</h5>
      <p class="text-muted mb-0">o haz clic para seleccionar</p>
      <span class="badge bg-light text-dark mt-2">Máx. 10MB por archivo</span>
    </div>
    <div class="drop-zone-uploading" style="display: none;">
      <div class="spinner-border text-primary" role="status"></div>
      <h5 class="mt-3">Subiendo archivos...</h5>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
      <i class="bi bi-images me-2"></i>Biblioteca de Medios
      <span class="badge bg-secondary ms-2" id="mediaCount"><%= media ? media.length : 0 %></span>
    </h5>
  </div>

  <% if (media && media.length > 0) { %>
    <div class="row g-3" id="mediaGrid">
      <% media.forEach(function(item) { %>
        <div class="col-6 col-md-4 col-lg-3 col-xl-2 media-col" data-id="<%= item.id %>">
          <div class="card media-item h-100 border-0 shadow-sm" onclick="openSidebar(<%= item.id %>)">
            <div class="media-preview">
              <% if (item.type === 'image') { %>
                <img src="<%= item.url %>" class="card-img-top" alt="<%= item.alt_text || item.filename %>">
                <div class="media-type-badge">
                  <i class="bi bi-image"></i>
                </div>
              <% } else if (item.type === 'video') { %>
                <div class="media-placeholder bg-dark">
                  <i class="bi bi-camera-video text-white" style="font-size: 2.5rem;"></i>
                </div>
                <div class="media-type-badge bg-dark">
                  <i class="bi bi-camera-video"></i>
                </div>
              <% } else if (item.type === 'audio') { %>
                <div class="media-placeholder" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                  <i class="bi bi-music-note text-white" style="font-size: 2.5rem;"></i>
                </div>
                <div class="media-type-badge" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                  <i class="bi bi-music-note"></i>
                </div>
              <% } else { %>
                <div class="media-placeholder bg-gradient" style="background: linear-gradient(135deg, #6b7280 0%, #374151 100%);">
                  <i class="bi bi-file-earmark-text text-white" style="font-size: 2.5rem;"></i>
                </div>
                <div class="media-type-badge" style="background: linear-gradient(135deg, #6b7280 0%, #374151 100%);">
                  <i class="bi bi-file-earmark-text"></i>
                </div>
              <% } %>
            </div>
            <div class="card-body p-2">
              <p class="card-title small fw-medium text-truncate mb-1" title="<%= item.original_name %>">
                <%= item.original_name %>
              </p>
              <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted"><%= formatFileSize(item.size) %></small>
                <small class="text-muted"><%= item.extension %></small>
              </div>
            </div>
            <div class="card-footer bg-transparent border-0 p-2">
              <div class="btn-group btn-group-sm w-100">
                <button class="btn btn-outline-primary" onclick="event.stopPropagation(); copyUrl('<%= item.url %>')" title="Copiar URL">
                  <i class="bi bi-link-45deg"></i>
                </button>
                <button class="btn btn-outline-danger" onclick="event.stopPropagation(); deleteMedia(<%= item.id %>, '<%= item.original_name %>')" title="Eliminar">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      <%}); %>
    </div>
  <% } else { %>
    <div class="text-center py-5" id="emptyState">
      <div class="empty-state-icon">
        <i class="bi bi-images"></i>
      </div>
      <h5 class="mt-3">No se encontraron medios</h5>
      <p class="text-muted">Arrastra archivos aquí para comenzar</p>
    </div>
  <% } %>
</div>

<div id="mediaSidebar" class="media-sidebar">
  <div class="sidebar-header">
    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Detalles</h5>
    <button class="btn btn-sm btn-outline-secondary" onclick="closeSidebar()">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>
  <div class="sidebar-body" id="sidebarContent">
    <div class="text-center py-5">
      <div class="spinner-border spinner-border-sm" role="status"></div>
      <p class="mt-2 text-muted">Cargando...</p>
    </div>
  </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="copyToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body">
        <i class="bi bi-check-circle me-2"></i>URL copiada al portapapeles
      </div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<form id="hiddenUploadForm" action="/admin/media" method="POST" enctype="multipart/form-data" style="display: none;">
  <input type="file" id="hiddenFileInput" name="file" multiple>
</form>

<script>
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
  }

  const dropZone = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');
  const uploadForm = document.getElementById('uploadForm');
  const uploadingContent = dropZone.querySelector('.drop-zone-uploading');
  const content = dropZone.querySelector('.drop-zone-content');

  dropZone.addEventListener('click', () => fileInput.click());
  
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });
  
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('drag-over');
  });
  
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      fileInput.files = files;
      uploadFiles();
    }
  });
  
  fileInput.addEventListener('change', () => {
    if (fileInput.files.length > 0) {
      uploadFiles();
    }
  });

  function uploadFiles() {
    content.style.display = 'none';
    uploadingContent.style.display = 'block';
    
    const formData = new FormData(uploadForm);
    
    fetch('/admin/media', {
      method: 'POST',
      body: formData
    })
    .then(res => res.json())
    .then(data => {
      if (data.success || data.message) {
        location.reload();
      }
    })
    .catch(err => {
      content.style.display = 'block';
      uploadingContent.style.display = 'none';
      Swal.fire({ icon: 'error', title: 'Error al subir archivos' });
    });
  }

  function openSidebar(id) {
    const sidebar = document.getElementById('mediaSidebar');
    const content = document.getElementById('sidebarContent');
    sidebar.classList.add('open');
    
    content.innerHTML = '<div class="text-center py-5"><div class="spinner-border spinner-border-sm" role="status"></div><p class="mt-2 text-muted">Cargando...</p></div>';
    
    fetch(`/admin/media/${id}`)
      .then(res => res.text())
      .then(html => {
        content.innerHTML = html;
      })
      .catch(err => {
        content.innerHTML = '<div class="alert alert-danger">Error al cargar</div>';
      });
  }

  function closeSidebar() {
    document.getElementById('mediaSidebar').classList.remove('open');
  }

  function copyUrl(url) {
    navigator.clipboard.writeText(window.location.origin + url).then(() => {
      const toast = new bootstrap.Toast(document.getElementById('copyToast'));
      toast.show();
    });
  }

  function deleteMedia(id, name) {
    Swal.fire({
      title: '¿Eliminar archivo?',
      text: `"${name}" será eliminado permanentemente`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Sí, eliminar',
      cancelButtonText: 'Cancelar',
      confirmButtonColor: '#dc3545'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch(`/admin/media/${id}`, {
          method: 'DELETE',
          headers: { 
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          }
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            const element = document.querySelector(`.media-col[data-id="${id}"]`);
            if (element) {
              element.style.transition = 'all 0.3s';
              element.style.opacity = '0';
              element.style.transform = 'scale(0.8)';
              setTimeout(() => {
                element.remove();
                const count = document.querySelectorAll('.media-col').length;
                document.getElementById('mediaCount').textContent = count;
                if (count === 0) {
                  location.reload();
                }
              }, 300);
            }
            Swal.fire({ icon: 'success', title: 'Eliminado', timer: 1500 });
          } else {
            Swal.fire({ icon: 'error', title: data.message || 'Error al eliminar' });
          }
        });
      }
    });
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeSidebar();
    }
  });

  // Socket.IO integration
  const socket = io();
  
  socket.on('media:created', function(data) {
    console.log('Medio creado:', data);
    const countEl = document.getElementById('mediaCount');
    if (countEl) {
      countEl.textContent = parseInt(countEl.textContent) + 1;
    }
    const emptyState = document.getElementById('emptyState');
    if (emptyState) {
      emptyState.remove();
    }
    const grid = document.getElementById('mediaGrid');
    if (grid) {
      const html = createMediaCard(data);
      grid.insertAdjacentHTML('afterbegin', html);
      grid.querySelector('.media-col').style.animation = 'fadeIn 0.3s ease';
    }
    Swal.fire({
      position: 'top-end',
      icon: 'success',
      title: 'Nuevo medio subido',
      text: data.original_name,
      showConfirmButton: false,
      timer: 3000,
      toast: true
    });
  });

  socket.on('media:deleted', function(data) {
    console.log('Medio eliminado:', data);
    const element = document.querySelector(`.media-col[data-id="${data.id}"]`);
    if (element) {
      element.style.transition = 'all 0.3s';
      element.style.opacity = '0';
      element.style.transform = 'scale(0.8)';
      setTimeout(() => {
        element.remove();
        const count = document.querySelectorAll('.media-col').length;
        document.getElementById('mediaCount').textContent = count;
      }, 300);
    }
  });

  function createMediaCard(item) {
    const isImage = item.type === 'image';
    const imgHtml = isImage ? `<img src="${item.url}" class="card-img-top" alt="${item.alt_text || item.filename}">` : '';
    const iconClass = isImage ? 'bi-image' : (item.type === 'video' ? 'bi-camera-video' : (item.type === 'audio' ? 'bi-music-note' : 'bi-file-earmark-text'));
    const bgClass = isImage ? '' : (item.type === 'video' ? 'bg-dark' : (item.type === 'audio' ? '' : 'bg-gradient'));
    const style = item.type === 'audio' ? 'background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);' : (item.type !== 'video' ? 'background: linear-gradient(135deg, #6b7280 0%, #374151 100%);' : '');
    
    return `<div class="col-6 col-md-4 col-lg-3 col-xl-2 media-col" data-id="${item.id}">
      <div class="card media-item h-100 border-0 shadow-sm" onclick="openSidebar(${item.id})">
        <div class="media-preview">
          ${imgHtml}
          <div class="media-type-badge ${bgClass}" ${style ? 'style="' + style + '"' : ''}>
            <i class="bi ${iconClass}"></i>
          </div>
        </div>
        <div class="card-body p-2">
          <p class="card-title small fw-medium text-truncate mb-1">${item.original_name}</p>
          <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">${formatFileSize(item.size)}</small>
            <small class="text-muted">${item.extension}</small>
          </div>
        </div>
        <div class="card-footer bg-transparent border-0 p-2">
          <div class="btn-group btn-group-sm w-100">
            <button class="btn btn-outline-primary" onclick="event.stopPropagation(); copyUrl('${item.url}')">
              <i class="bi bi-link-45deg"></i>
            </button>
            <button class="btn btn-outline-danger" onclick="event.stopPropagation(); deleteMedia(${item.id}, '${item.original_name}')">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
      </div>
    </div>`;
  }
</script>

<style>
  .nav-pills .nav-link {
    border-radius: 20px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .nav-pills .nav-link:hover {
    background: rgba(13, 110, 253, 0.1);
  }
  .nav-pills .nav-link.active {
    background: #0d6efd;
    box-shadow: 0 2px 8px rgba(13, 110, 253, 0.3);
  }
  
  .drop-zone {
    border: 2px dashed #dee2e6;
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    position: relative;
    overflow: hidden;
  }
  .drop-zone:hover {
    border-color: #0d6efd;
    background: linear-gradient(135deg, #e7f1ff 0%, #d0e1ff 100%);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(13, 110, 253, 0.15);
  }
  .drop-zone.drag-over {
    border-color: #0d6efd;
    background: linear-gradient(135deg, #d0e1ff 0%, #a8d0ff 100%);
    transform: scale(1.02);
  }
  .drop-zone-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto;
    background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pulse 2s infinite;
  }
  .drop-zone-icon i {
    font-size: 2.5rem;
    color: white;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
  
  .media-item {
    cursor: pointer;
    transition: all 0.3s ease;
    overflow: hidden;
  }
  .media-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
  }
  .media-preview {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #f8f9fa;
    position: relative;
  }
  .media-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .media-item:hover .media-preview img {
    transform: scale(1.1);
  }
  .media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .media-type-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0,0,0,0.6);
    color: white;
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.75rem;
  }
  
  .media-sidebar {
    position: fixed;
    top: 0;
    right: -420px;
    width: 420px;
    max-width: 100%;
    height: 100vh;
    background: white;
    box-shadow: -4px 0 20px rgba(0,0,0,0.15);
    z-index: 1055;
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .media-sidebar.open {
    right: 0;
  }
  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #dee2e6;
    background: #f8f9fa;
  }
  .sidebar-body {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
  }
  
  .empty-state-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto;
    background: linear-gradient(135deg, #e9ecef 0%, #dee2e6 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .empty-state-icon i {
    font-size: 3rem;
    color: #adb5bd;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @media (max-width: 768px) {
    .media-sidebar {
      width: 100%;
      right: -100%;
    }
    .media-col {
      col-6: 1;
      col-md-4: 1;
      col-lg-3: 1;
      col-xl-2: 1;
    }
  }
</style>
