<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-body">
        <% if (media) { %>
          <% if (media.type === 'image') { %>
            <img src="<%= media.url %>" class="img-fluid mb-3" alt="<%= media.alt_text || media.filename %>">
          <% } else if (media.type === 'video') { %>
            <video src="<%= media.url %>" class="w-100 mb-3" controls></video>
          <% } else if (media.type === 'audio') { %>
            <audio src="<%= media.url %>" class="w-100 mb-3" controls></audio>
          <% } else { %>
            <div class="text-center py-5 bg-light mb-3">
              <i class="bi bi-file-earmark-text" style="font-size: 4rem;"></i>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h6 class="mb-0">Detalles del archivo</h6>
      </div>
      <div class="card-body">
        <% if (media) { %>
          <p><strong>Nombre:</strong> <%= media.original_name %></p>
          <p><strong>Tipo:</strong> <%= media.mime_type %></p>
          <p><strong>Tamaño:</strong> <%= (media.size / 1024).toFixed(2) %> KB</p>
          <p><strong>Subido:</strong> <%= new Date(media.createdAt).toLocaleDateString('es-ES') %></p>
          <% if (media.author) { %>
            <p><strong>Por:</strong> <%= media.author.name %></p>
          <% } %>
        <% } %>
      </div>
    </div>
    
    <div class="card mt-3">
      <div class="card-header">
        <h6 class="mb-0">Editar metadatos</h6>
      </div>
      <div class="card-body">
        <form action="/admin/media/<%= media ? media.id + '?_method=PUT' : '' %>" method="POST">
          <div class="mb-3">
            <label for="alt_text" class="form-label">Texto alternativo (Alt)</label>
            <input type="text" class="form-control" id="alt_text" name="alt_text" value="<%= media ? media.alt_text || '' : '' %>">
          </div>
          
          <div class="mb-3">
            <label for="caption" class="form-label">Título/Caption</label>
            <input type="text" class="form-control" id="caption" name="caption" value="<%= media ? media.caption || '' : '' %>">
          </div>
          
          <div class="mb-3">
            <label for="description" class="form-label">Descripción</label>
            <textarea class="form-control" id="description" name="description" rows="3"><%= media ? media.description || '' : '' %></textarea>
          </div>
          
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check"></i> Guardar
            </button>
            <a href="/admin/media" class="btn btn-secondary">Volver</a>
          </div>
        </form>
      </div>
    </div>
    
    <div class="card mt-3">
      <div class="card-body">
        <button class="btn btn-danger w-100" onclick="deleteMedia(<%= media ? media.id : 0 %>)">
          <i class="bi bi-trash"></i> Eliminar permanentemente
        </button>
      </div>
    </div>
  </div>
</div>

<script>
function deleteMedia(id) {
  if (confirm('¿Estás seguro de eliminar este medio? Esta acción no se puede deshacer.')) {
    fetch(`/admin/media/${id}`, {
      method: 'DELETE',
      headers: { 
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      }
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        window.location.href = '/admin/media';
      } else {
        alert(data.message || 'Error al eliminar');
      }
    })
    .catch(err => {
      alert('Error al eliminar medio');
    });
  }
}
</script>
